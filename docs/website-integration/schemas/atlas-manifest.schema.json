{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/atlas-manifest.schema.json",
  "title": "Static Atlas Manifest",
  "type": "object",
  "required": ["schema_version", "id", "title", "kind", "route", "generated_at", "source", "stats", "papers"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": { "type": "string" },
    "kind": { "type": "string" },
    "route": {
      "type": "string",
      "pattern": "^/"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "required": ["content_root", "taxonomy_path", "paper_count"],
      "properties": {
        "content_root": { "type": "string" },
        "taxonomy_path": { "type": "string" },
        "paper_count": { "type": "integer", "minimum": 0 }
      }
    },
    "stats": {
      "type": "object",
      "required": ["paper_count", "axis_A_counts", "axis_B_counts"],
      "properties": {
        "paper_count": { "type": "integer", "minimum": 0 },
        "year_min": { "type": ["integer", "null"] },
        "year_max": { "type": ["integer", "null"] },
        "axis_A_counts": { "type": "object" },
        "axis_B_counts": { "type": "object" },
        "axis_C_object_vocab_counts": { "type": "object" },
        "axis_D_rewrite_type_counts": { "type": "object" }
      }
    },
    "papers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "title", "route", "summary", "axis_A", "axis_B"],
        "additionalProperties": true,
        "properties": {
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "route": { "type": "string" },
          "summary": { "type": "string" },
          "axis_A": { "type": "object" },
          "axis_B": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
