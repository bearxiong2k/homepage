---
type ProjectEntry = {
  id: string;
  title: string;
  kind?: string;
  status?: string;
  summary: string;
  route: string;
  landing_route?: string;
  tags?: string[];
  featured?: boolean;
};

interface Props {
  project: ProjectEntry;
}

const { project } = Astro.props;
const href = project.landing_route || project.route;
---

<article class="project-card">
  <p class="project-card__eyebrow">{project.kind}{project.status ? ` · ${project.status}` : ''}</p>
  <h2><a href={href}>{project.title}</a></h2>
  <p>{project.summary}</p>
  {project.tags?.length ? (
    <ul class="project-card__tags" aria-label={`${project.title} tags`}>
      {project.tags.map((tag) => <li>{tag}</li>)}
    </ul>
  ) : null}
  <a class="project-card__link" href={project.route}>Open project</a>
</article>
